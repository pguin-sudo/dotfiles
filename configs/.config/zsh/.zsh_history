: 1756746468:0;# –ГБ–Њ–Ј–і–∞–µ–Љ —Г§–∞–є–ї .editorconfig –і–ї—Гѓ –µ–і–Є–љ–Њ–Њ–±—А–∞–Ј–Є—Гѓ —Г§–Њ—А–Љ–∞—В–Є—А–Њ–≤–∞–љ–Є—Гѓ\
cat > .editorconfig << 'EOL'\
root = true\
\
[*]\
indent_style = space\
indent_size = 2\
end_of_line = lf\
charset = utf-8\
trim_trailing_whitespace = true\
insert_final_newline = true\
\
[*.md]\
trim_trailing_whitespace = false\
EOL\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ vim-–њ–ї–∞–≥–Є–љ –і–ї—Гѓ —А–∞–±–Њ—В—ГЂ —Б –≤–Є–Ї–Є-—Б—Б—ГЂ–ї–Ї–∞–Љ–Є\
mkdir -p .vim/pack/wiki/start\
cd .vim/pack/wiki/start\
git clone https://github.com/vimwiki/vimwiki.git\
cd ../../../../\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ –±–∞–Ј–Њ–≤—ГЂ–є .vimrc –Ї–Њ–љ—Г§–Є–≥ –і–ї—Гѓ —А–∞–±–Њ—В—ГЂ —Б markdown —Г§–∞–є–ї–∞–Љ–Є\
cat > .vimrc << 'EOL'\
set nocompatible\
filetype plugin on\
syntax on\
\
" –Гљ–∞—Б—В—А–Њ–є–Ї–Є –і–ї—Гѓ markdown\
autocmd FileType markdown setlocal wrap\
autocmd FileType markdown setlocal linebreak\
autocmd FileType markdown setlocal spell spelllang=ru_ru,en_us\
\
" –Гљ–∞—Б—В—А–Њ–є–Ї–Є —В–∞–±—Г£–ї—Гѓ—Г¶–Є–Є\
set tabstop=2\
set shiftwidth=2\
set expandtab\
\
" –Г≤–Ї–ї—ГЃ—ГІ–µ–љ–Є–µ –љ–∞–≤–Є–≥–∞—Г¶–Є–Є –њ–Њ wiki-—Б—Б—ГЂ–ї–Ї–∞–Љ\
let g:vimwiki_list = [{'path': '.', 'syntax': 'markdown', 'ext': '.md'}]\
EOL
: 1756748352:0;# –ГБ–Њ–Ј–і–∞–µ–Љ —Б–Є–Љ–ї–Є–љ–Ї–Є –і–ї—Гѓ –±—ГЂ—Б—В—А–Њ–≥–Њ –і–Њ—Б—В—Г£–њ–∞ –Ї —ГІ–∞—Б—В–Њ –Є—Б–њ–Њ–ї—Гђ–Ј—Г£–µ–Љ—ГЂ–Љ —А–∞–Ј–і–µ–ї–∞–Љ\
ln -s "Knowledge/University/–Гі–Є—Б—Г¶–Є–њ–ї–Є–љ—ГЂ" "Subjects"\
ln -s "Knowledge/IT" "IT"\
ln -s "Knowledge/University/–Г∞–і–Љ–Є–љ–Є—Б—В—А–Є—А–Њ–≤–∞–љ–Є–µ" "Admin"\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ –њ–∞–њ–Ї—Г£ –і–ї—Гѓ –µ–ґ–µ–і–љ–µ–≤–љ—ГЂ—Г• –Ј–∞–Љ–µ—В–Њ–Ї (–і–ї—Гѓ Daily Notes –≤ Obsidian)\
mkdir -p "Journals"\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ –њ–∞–њ–Ї—Г£ –і–ї—Гѓ –∞—В—В–∞—ГІ–Љ–µ–љ—В–Њ–≤ (–Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є–є, —Г§–∞–є–ї–Њ–≤)\
mkdir -p "Attachments"\
\
# –Гњ–µ—А–µ–Є–Љ–µ–љ–Њ–≤—ГЂ–≤–∞–µ–Љ –њ–∞–њ–Ї–Є –і–ї—Гѓ –±–Њ–ї—Гђ—Г®–µ–є –Ї–Њ–љ—Б–Є—Б—В–µ–љ—В–љ–Њ—Б—В–Є\
mv "Knowledge/–ГЉ—ГЂ—Б–ї–Є/–ГЄ–љ–Ї—Г£–±–∞—В–Њ—А" "Knowledge/–ГЉ—ГЂ—Б–ї–Є/Inbox"\
mv "Notes/Inbox.md" "Notes/Inbox/Inbox.md"\
mkdir -p "Notes/Inbox"\
mv "Notes/–ГЇ–Њ–љ—Б–њ–µ–Ї—В—ГЂ" "Notes/Notes"\
mv "Notes/Meta" "Notes/Metadata"\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ —Г§–∞–є–ї –і–ї—Гѓ –±—ГЂ—Б—В—А–Њ–≥–Њ –њ–Њ–Є—Б–Ї–∞ —В–µ–≥–Њ–≤\
touch "Tags.md"\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ —Г§–∞–є–ї –і–ї—Гѓ –Њ—Б–љ–Њ–≤–љ—ГЂ—Г• –Ї–∞—А—В –Ј–љ–∞–љ–Є–є (MOC - Map of Content)\
touch "MOCs.md"
: 1756748396:0;# –ГБ–Њ–Ј–і–∞–µ–Љ —Б–Ї—А–Є–њ—В –і–ї—Гѓ –±—ГЂ—Б—В—А–Њ–≥–Њ —Б–Њ–Ј–і–∞–љ–Є—Гѓ –љ–Њ–≤—ГЂ—Г• –Ј–∞–Љ–µ—В–Њ–Ї\
cat > new_note << 'EOL'\
#!/bin/bash\
# –ГБ–Ї—А–Є–њ—В –і–ї—Гѓ —Б–Њ–Ј–і–∞–љ–Є—Гѓ –љ–Њ–≤—ГЂ—Г• –Ј–∞–Љ–µ—В–Њ–Ї —Б –±–∞–Ј–Њ–≤—ГЂ–Љ —Г®–∞–±–ї–Њ–љ–Њ–Љ\
NOTE_NAME="${1:-new_note}"\
NOTE_PATH="Notes/Inbox/${NOTE_NAME}.md"\
cp .obsidian/templates/Basic\ Note.md "$NOTE_PATH"\
sed -i "s/{{title}}/$NOTE_NAME/g" "$NOTE_PATH"\
sed -i "s/{{date}}/$(date '+%Y-%m-%d %H:%M')/g" "$NOTE_PATH"\
echo "Created new note: $NOTE_PATH"\
EOL\
\
chmod +x new_note\
\
# –ГБ–Њ–Ј–і–∞–µ–Љ —Б–Ї—А–Є–њ—В –і–ї—Гѓ —Б–Є–љ—Г•—А–Њ–љ–Є–Ј–∞—Г¶–Є–Є —Б git (—Г£—Б–Њ–≤–µ—А—Г®–µ–љ—Б—В–≤–Њ–≤–∞–љ–љ–∞—Гѓ –≤–µ—А—Б–Є—Гѓ)\
cat > bin/sync.sh << 'EOL'\
#!/bin/bash\
# –ГБ–Ї—А–Є–њ—В –і–ї—Гѓ –∞–≤—В–Њ–Љ–∞—В–Є—ГІ–µ—Б–Ї–Њ–є —Б–Є–љ—Г•—А–Њ–љ–Є–Ј–∞—Г¶–Є–Є —Б git\
\
cd "$(dirname "$0")/.."\
\
# –Гі–Њ–±–∞–≤–ї—Гѓ–µ–Љ –≤—Б–µ –Є–Ј–Љ–µ–љ–µ–љ–Є—Гѓ\
git add .\
\
# –ГЇ–Њ–Љ–Љ–Є—В–Є–Љ —Б —В–µ–Ї—Г£—Г©–µ–є –і–∞—В–Њ–є –Є –≤—А–µ–Љ–µ–љ–µ–Љ\
git commit -m "Automatic sync: $(date '+%Y-%m-%d %H:%M:%S')"\
\
# –Гњ—Г£—Г®–Є–Љ –Є–Ј–Љ–µ–љ–µ–љ–Є—Гѓ\
git push origin main\
\
echo "Sync completed at $(date '+%Y-%m-%d %H:%M:%S')"\
EOL\
\
chmod +x bin/sync.sh
: 1756748421:0;# –ГЊ–±–љ–Њ–≤–ї—Гѓ–µ–Љ Index.md –і–ї—Гѓ –Њ—В—А–∞–ґ–µ–љ–Є—Гѓ –љ–Њ–≤–Њ–є —Б—В—А—Г£–Ї—В—Г£—А—ГЂ\
cat > Index.md << 'EOL'\
# My Knowledge System\
\
## Quick Navigation\
- [[Subjects]] - University subjects\
- [[IT]] - IT knowledge base\
- [[Admin]] - University administration\
- [[Notes/Inbox]] - Quick notes\
- [[Journals]] - Daily journals\
- [[TODO/in]] - Task inbox\
\
## Key Features\
- Optimized for Obsidian and Vim\
- Daily notes support\
- Template system\
- Automated sync with git\
\
## Structure\
- `Knowledge/` - Structured knowledge\
- `Notes/` - Fleeting and literature notes\
- `TODO/` - GTD-based task management\
- `Journals/` - Daily notes\
- `Attachments/` - Images and files\
EOL
